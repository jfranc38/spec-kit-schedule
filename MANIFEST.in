# MANIFEST.in vs `[tool.setuptools.data-files]` (pyproject.toml):
#
# - This file controls the SDIST contents (`uv build --sdist` /
#   `python -m build --sdist`) and supplements wheel data inclusion when
#   `include-package-data = true`.
# - The `data-files` block in pyproject.toml is what produces the
#   `share/spec-kit-schedule/...` payload INSIDE the wheel/sdist so the
#   spec-kit `specify` CLI can locate the extension after install.
#
# Both must list the asset paths; one without the other ships an
# incomplete artifact. Keep them in sync when adding new commands or
# templates.
include LICENSE
include README.md
include CHANGELOG.md
include INSTALL.md
include extension.yml
include config-template.yml
include pyproject.toml
recursive-include commands *.md
recursive-include templates *
recursive-include bin *
recursive-include docs *.md *.yml
prune docs/archive
prune tests
prune benchmarks
prune .github
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude .DS_Store
